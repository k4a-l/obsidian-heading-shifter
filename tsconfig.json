{
	"compilerOptions": {
		"paths": {
			"*": ["./src/*"]
		},
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "es2020",
		"target": "esnext",
		"esModuleInterop": true,
		"allowJs": true,
		"moduleResolution": "bundler",
		"importHelpers": true,
		"isolatedModules": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"lib": ["DOM", "ES5", "ES6", "ES7", "ES2022"]
	},
	"include": ["src", "test"]
}
