{
	"name": "obsidian-heading-shifter",
	"version": "1.12.0",
	"description": "Easily shift multiple heading of markdown",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"tsc": "tsc -noEmit",
		"tsc:watch": "tsc -noEmit --watch",
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json package.json && npm run check",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"lint": "biome lint --write && eslint . --fix",
		"format": "biome format --write && remark . --output",
		"check": "biome check --write && eslint . --fix",
		"ci": "biome ci && eslint .",
		"prepare": "husky"
	},
	"keywords": [],
	"author": "kasahala",
	"url": "https://github.com/k4a-l/obsidian-heading-shifter",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@cspell/eslint-plugin": "^10.0.1",
		"@types/node": "^26.1.0",
		"@types/semver": "^7.7.1",
		"@vitest/coverage-v8": "^4.1.9",
		"esbuild": "0.28.1",
		"eslint": "^10.6.0",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"husky": "^9.1.7",
		"obsidian": "latest",
		"remark": "^15.0.1",
		"remark-cli": "^12.0.1",
		"remark-preset-lint-recommended": "^7.0.1",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@codemirror/state": "^6.7.0",
		"@codemirror/view": "^6.43.4",
		"immer": "^11.1.9",
		"semver": "^7.8.5",
		"ts-pattern": "^5.9.0"
	},
	"remarkConfig": {
		"settings": {
			"bullet": "-"
		},
		"plugins": [
			"remark-preset-lint-recommended"
		]
	}
}
